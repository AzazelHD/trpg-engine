{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Engine Build (Debug)",
      "type": "shell",
      "command": "${workspaceFolder}/tools/build_debug.bat",
      "group": "build",
      "problemMatcher": ["$msCompile"]
    },
    {
      "label": "Engine Build (Release)",
      "type": "shell",
      "command": "${workspaceFolder}/tools/build_release.bat",
      "group": "build",
      "problemMatcher": ["$msCompile"]
    },
    {
      "label": "Engine Install (Release)",
      "type": "shell",
      "command": "cmd.exe",
      "args": [
        "/d",
        "/c",
        "${workspaceFolder}/tools/vsenv.bat cmake --install build --config Release"
      ],
      "problemMatcher": []
    },
    {
      "label": "Engine DEV",
      "dependsOrder": "sequence",
      "dependsOn": ["Engine Configure", "Engine Build (Debug)"],
      "problemMatcher": []
    },
    {
      "label": "Engine FINAL",
      "dependsOrder": "sequence",
      "dependsOn": ["Engine Configure", "Engine Build (Release)", "Engine Install (Release)"],
      "problemMatcher": []
    }
  ]
}
